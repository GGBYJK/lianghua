MARKET_DATA_PROVIDER=tqsdk

# TqSdk market data provider. c0 is mapped to KQ.m@DCE.c by default.
TQ_ACCOUNT=your-shinny-account
TQ_PASSWORD=your-shinny-password
TQ_DEFAULT_EXCHANGE=DCE
TQ_TIMEOUT=30
TQ_FIRST_DATA_TIMEOUT=30
TQ_REQUEST_TIMEOUT=30
TQ_MIN_DATA_LENGTH=240

# Watch pool scanning
WATCH_POOL_KLINE_LIMIT=240
WATCH_POOL_SCAN_CONCURRENCY=3

# Aliyun market data provider. Keep these if you need to switch back later.
ALIYUN_MARKET_KLINE_URL=https://your-aliyun-market-kline-url
ALIYUN_MARKET_APPCODE=your-app-code

# Optional Aliyun parameter overrides
ALIYUN_MARKET_SYMBOL_PARAM=symbol
ALIYUN_MARKET_PERIOD_PARAM=type
ALIYUN_MARKET_LIMIT_PARAM=limit
ALIYUN_MARKET_EXTRA_PARAMS=
ALIYUN_MARKET_TIMEOUT=10

# Watch pool database. In Docker/production this must point to a reachable MySQL
# host, not 127.0.0.1 unless MySQL runs inside the same backend container.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=lh_demo

# Enterprise WeChat robot notification. Keep the real key in .env only.
WECHAT_WORKBOT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key
WECHAT_WORKBOT_MENTIONED_LIST=
WECHAT_WORKBOT_TIMEOUT_SECONDS=8
